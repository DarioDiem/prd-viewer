{
  "name": "pacs-prd-mcp",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Local-only MCP server for derived PRD access in the PACS framework.",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:http": "PACS_MCP_TRANSPORT=http tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "build:plugin": "npm run build && esbuild dist/index.js --bundle --platform=node --format=esm --target=node20 --outfile=../plugins/pacs-context/mcp/index.mjs",
    "check": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/index.js",
    "start:http": "PACS_MCP_TRANSPORT=http node dist/index.js",
    "test": "node --import tsx --test src/*.test.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "esbuild": "^0.28.1",
    "tsx": "^4.23.1",
    "typescript": "^5.8.3"
  }
}
