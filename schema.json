{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/prd.schema.v1.2.0.json",
  "title": "PRD Schema (Reference)",
  "description": "Reference schema for a production-grade PRD JSON document. Use this file for section intent, field descriptions, and examples. Use schema.strict.json for strict machine validation.",
  "type": "object",
  "required": [
    "meta",
    "problem",
    "goals",
    "assumptions",
    "personas",
    "requirements",
    "user_stories",
    "constraints",
    "delivery",
    "risks",
    "open_questions",
    "decisions"
  ],
  "properties": {
    "meta": {
      "type": "object",
      "description": "Document-level metadata, ownership, and release context.",
      "required": [
        "prd_id",
        "title",
        "summary",
        "product_name",
        "document_type",
        "version",
        "status",
        "lifecycle_stage",
        "owners",
        "authors",
        "reviewers",
        "approvers",
        "created_at",
        "updated_at",
        "target_release",
        "stakeholders",
        "source_brief"
      ],
      "properties": {
        "prd_id": {
          "type": "string",
          "description": "Stable PRD identifier. Prefer UUIDv4."
        },
        "title": {
          "type": "string",
          "description": "PRD title."
        },
        "summary": {
          "type": "string",
          "description": "1-3 sentence executive summary of what is being built and why."
        },
        "product_name": {
          "type": "string",
          "description": "Product, platform, or initiative name."
        },
        "document_type": {
          "type": "string",
          "enum": [
            "prd"
          ]
        },
        "version": {
          "type": "string",
          "description": "Semantic version string, such as 1.0.0."
        },
        "status": {
          "type": "string",
          "enum": [
            "draft",
            "in_review",
            "approved",
            "implemented",
            "deprecated"
          ]
        },
        "lifecycle_stage": {
          "type": "string",
          "enum": [
            "discovery",
            "definition",
            "delivery",
            "launch",
            "live"
          ]
        },
        "owners": {
          "type": "object",
          "description": "Directly responsible owners by discipline.",
          "required": [
            "product",
            "engineering",
            "design",
            "business",
            "compliance"
          ],
          "properties": {
            "product": {
              "type": [
                "string",
                "null"
              ]
            },
            "engineering": {
              "type": [
                "string",
                "null"
              ]
            },
            "design": {
              "type": [
                "string",
                "null"
              ]
            },
            "business": {
              "type": [
                "string",
                "null"
              ]
            },
            "compliance": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        },
        "authors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "reviewers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "approvers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        },
        "target_release": {
          "type": [
            "string",
            "null"
          ],
          "description": "Release identifier or date, if known."
        },
        "stakeholders": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/stakeholder"
          }
        },
        "source_brief": {
          "type": [
            "string",
            "null"
          ],
          "description": "Reference to the input brief or source document."
        },
        "links": {
          "type": "array",
          "description": "Optional supporting links such as design files, docs, or tickets.",
          "items": {
            "$ref": "#/$defs/link"
          }
        },
        "schema_contract": {
          "$ref": "#/$defs/schema_contract",
          "description": "Optional schema contract metadata that declares which framework schema version this PRD targets, which versions are compatible, and which extensions or migrations apply."
        }
      }
    },
    "problem": {
      "type": "object",
      "description": "Problem framing and supporting context.",
      "required": [
        "statement",
        "background",
        "opportunity",
        "strategic_fit",
        "affected_users",
        "evidence"
      ],
      "properties": {
        "statement": {
          "type": "string"
        },
        "background": {
          "type": "string"
        },
        "opportunity": {
          "type": "string"
        },
        "strategic_fit": {
          "type": [
            "string",
            "null"
          ]
        },
        "affected_users": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "evidence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidence"
          }
        }
      }
    },
    "goals": {
      "type": "object",
      "description": "Business outcomes, user outcomes, measures of success, and explicit non-goals.",
      "required": [
        "business_goals",
        "user_outcomes",
        "success_metrics",
        "guardrail_metrics",
        "non_goals"
      ],
      "properties": {
        "business_goals": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/business_goal"
          }
        },
        "user_outcomes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/user_outcome"
          }
        },
        "success_metrics": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/metric"
          }
        },
        "guardrail_metrics": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/metric"
          }
        },
        "non_goals": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "assumptions": {
      "type": "array",
      "description": "Explicit assumptions that need validation or ongoing monitoring.",
      "items": {
        "$ref": "#/$defs/assumption"
      }
    },
    "personas": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/persona"
      }
    },
    "requirements": {
      "type": "object",
      "required": [
        "functional",
        "non_functional"
      ],
      "properties": {
        "functional": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/functional_requirement"
          }
        },
        "non_functional": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_functional_requirement"
          }
        }
      }
    },
    "user_stories": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/user_story"
      }
    },
    "constraints": {
      "type": "object",
      "required": [
        "technical",
        "legal_compliance",
        "dependencies"
      ],
      "properties": {
        "technical": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/technical_constraint"
          }
        },
        "legal_compliance": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/legal_compliance"
          }
        },
        "dependencies": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/dependency"
          }
        }
      }
    },
    "delivery": {
      "type": "object",
      "description": "Release planning, rollout, and operational readiness.",
      "required": [
        "target_launch",
        "milestones",
        "rollout_plan",
        "operational_readiness"
      ],
      "properties": {
        "target_launch": {
          "type": [
            "string",
            "null"
          ],
          "format": "date"
        },
        "milestones": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/milestone"
          }
        },
        "rollout_plan": {
          "$ref": "#/$defs/rollout_plan"
        },
        "operational_readiness": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/readiness_item"
          }
        }
      }
    },
    "project_tracking": {
      "$ref": "#/$defs/project_tracking",
      "description": "First-class project execution state for the PRD, including pending work, issues, blockers, and operator notes."
    },
    "risks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/risk"
      }
    },
    "open_questions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/open_question"
      }
    },
    "decisions": {
      "type": "array",
      "description": "Important decisions already made or proposed as part of the PRD.",
      "items": {
        "$ref": "#/$defs/decision"
      }
    },
    "extensions": {
      "$ref": "#/$defs/extensions_container",
      "description": "Optional namespaced extension registry and extension data. Core PRD agents may ignore unsupported extensions unless an extension is marked required."
    }
  },
  "$defs": {
    "link": {
      "type": "object",
      "properties": {
        "label": {
          "type": "string"
        },
        "url": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "stakeholder": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "role": {
          "type": "string"
        },
        "team": {
          "type": [
            "string",
            "null"
          ]
        },
        "approval_required": {
          "type": "boolean"
        }
      }
    },
    "evidence": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "metric",
            "user_research",
            "competitor",
            "support_ticket",
            "regulatory",
            "internal_data",
            "other"
          ]
        },
        "description": {
          "type": "string"
        },
        "source": {
          "type": "string"
        },
        "confidence": {
          "type": "string",
          "enum": [
            "high",
            "medium",
            "low"
          ]
        },
        "observed_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date"
        }
      }
    },
    "business_goal": {
      "type": "object",
      "properties": {
        "statement": {
          "type": "string"
        },
        "rationale": {
          "type": [
            "string",
            "null"
          ]
        },
        "owner": {
          "type": [
            "string",
            "null"
          ]
        },
        "priority": {
          "type": "string",
          "enum": [
            "primary",
            "secondary"
          ]
        }
      }
    },
    "user_outcome": {
      "type": "object",
      "properties": {
        "actor": {
          "type": "string"
        },
        "desired_outcome": {
          "type": "string"
        },
        "measurement_signal": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "metric": {
      "type": "object",
      "properties": {
        "metric": {
          "type": "string"
        },
        "baseline": {
          "type": [
            "string",
            "number",
            "null"
          ]
        },
        "target": {
          "type": [
            "string",
            "number"
          ]
        },
        "unit": {
          "type": "string"
        },
        "measurement_method": {
          "type": "string"
        },
        "timeframe_days": {
          "type": "integer"
        }
      }
    },
    "assumption": {
      "type": "object",
      "properties": {
        "assumption_id": {
          "type": "string"
        },
        "statement": {
          "type": "string"
        },
        "category": {
          "type": "string",
          "enum": [
            "user",
            "business",
            "technical",
            "operational",
            "legal",
            "market",
            "data"
          ]
        },
        "validation_plan": {
          "type": [
            "string",
            "null"
          ]
        },
        "owner": {
          "type": [
            "string",
            "null"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "open",
            "validated",
            "invalidated",
            "deferred"
          ]
        }
      }
    },
    "persona": {
      "type": "object",
      "properties": {
        "persona_id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "role": {
          "type": "string"
        },
        "goals": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "needs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "pain_points": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "current_workarounds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "frequency_of_use": {
          "type": "string",
          "enum": [
            "daily",
            "weekly",
            "monthly",
            "occasional"
          ]
        },
        "technical_proficiency": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "environment": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "functional_requirement": {
      "type": "object",
      "properties": {
        "req_id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "rationale": {
          "type": [
            "string",
            "null"
          ]
        },
        "priority": {
          "type": "string",
          "enum": [
            "must",
            "should",
            "could",
            "wont"
          ]
        },
        "persona_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "dependencies": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "acceptance_criteria": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "status": {
          "type": "string",
          "enum": [
            "proposed",
            "approved",
            "deferred",
            "removed"
          ]
        },
        "release_phase": {
          "type": "string",
          "enum": [
            "mvp",
            "ga",
            "post_ga",
            "future"
          ]
        }
      }
    },
    "non_functional_requirement": {
      "type": "object",
      "properties": {
        "req_id": {
          "type": "string"
        },
        "category": {
          "type": "string",
          "enum": [
            "performance",
            "security",
            "scalability",
            "accessibility",
            "reliability",
            "compliance",
            "usability",
            "observability",
            "privacy"
          ]
        },
        "description": {
          "type": "string"
        },
        "target": {
          "type": "string"
        },
        "priority": {
          "type": "string",
          "enum": [
            "must",
            "should",
            "could",
            "wont"
          ]
        },
        "acceptance_criteria": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "user_story": {
      "type": "object",
      "properties": {
        "story_id": {
          "type": "string"
        },
        "epic": {
          "type": "string"
        },
        "persona_id": {
          "type": "string"
        },
        "priority": {
          "type": "string",
          "enum": [
            "must",
            "should",
            "could"
          ]
        },
        "release_phase": {
          "type": "string",
          "enum": [
            "mvp",
            "ga",
            "post_ga",
            "future"
          ]
        },
        "statement": {
          "type": "object",
          "properties": {
            "as_a": {
              "type": "string"
            },
            "i_want": {
              "type": "string"
            },
            "so_that": {
              "type": "string"
            }
          }
        },
        "acceptance_criteria": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/gwt"
          }
        },
        "linked_req_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "story_points": {
          "type": [
            "integer",
            "null"
          ]
        },
        "edge_cases": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "gwt": {
      "type": "object",
      "properties": {
        "given": {
          "type": "string"
        },
        "when": {
          "type": "string"
        },
        "then": {
          "type": "string"
        }
      }
    },
    "technical_constraint": {
      "type": "object",
      "properties": {
        "constraint_id": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "imposed_by": {
          "type": "string",
          "enum": [
            "team",
            "architecture",
            "third_party",
            "platform"
          ]
        },
        "impact": {
          "type": "string"
        }
      }
    },
    "legal_compliance": {
      "type": "object",
      "properties": {
        "regulation": {
          "type": "string"
        },
        "requirement": {
          "type": "string"
        },
        "region": {
          "type": "string"
        },
        "owner": {
          "type": [
            "string",
            "null"
          ]
        },
        "evidence_source": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "dependency": {
      "type": "object",
      "properties": {
        "dependency_id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "description": {
          "type": [
            "string",
            "null"
          ]
        },
        "type": {
          "type": "string",
          "enum": [
            "internal",
            "external",
            "third_party",
            "platform"
          ]
        },
        "owner": {
          "type": [
            "string",
            "null"
          ]
        },
        "required_by": {
          "type": [
            "string",
            "null"
          ],
          "format": "date"
        },
        "status": {
          "type": "string",
          "enum": [
            "pending",
            "in_progress",
            "blocked",
            "complete"
          ]
        }
      }
    },
    "milestone": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "date": {
          "type": [
            "string",
            "null"
          ],
          "format": "date"
        },
        "deliverable": {
          "type": "string"
        },
        "entry_criteria": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "exit_criteria": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "owner": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "rollout_plan": {
      "type": "object",
      "properties": {
        "strategy": {
          "type": "string"
        },
        "phases": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "audience": {
                "type": "string"
              },
              "success_criteria": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "owner": {
                "type": [
                  "string",
                  "null"
                ]
              }
            }
          }
        },
        "communications": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "training": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "support_handoff": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "readiness_item": {
      "type": "object",
      "properties": {
        "area": {
          "type": "string"
        },
        "owner": {
          "type": [
            "string",
            "null"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "not_started",
            "in_progress",
            "ready",
            "blocked"
          ]
        },
        "notes": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "project_tracking": {
      "type": "object",
      "description": "Structured project status for the PRD that complements approval readiness and delivery planning.",
      "required": [
        "status",
        "owner",
        "summary",
        "updated_at",
        "linked_prd_ids",
        "pending_work",
        "issues_found",
        "blockers",
        "notes"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "not_started",
            "in_progress",
            "at_risk",
            "blocked",
            "completed",
            "on_hold",
            "cancelled"
          ],
          "description": "Overall execution state for the PRD-backed initiative."
        },
        "owner": {
          "type": [
            "string",
            "null"
          ],
          "description": "Current owner of the project tracking view."
        },
        "summary": {
          "type": [
            "string",
            "null"
          ],
          "description": "Short status narrative suitable for dashboards or handoff."
        },
        "updated_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time",
          "description": "Last time the project tracking section was refreshed."
        },
        "linked_prd_ids": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Stable PRD identifiers covered by this project tracking section."
        },
        "pending_work": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/project_tracking_work_item"
          },
          "description": "Backlog items required to advance the PRD."
        },
        "issues_found": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/project_tracking_issue"
          },
          "description": "Current known defects, gaps, or review findings."
        },
        "blockers": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/project_tracking_blocker"
          },
          "description": "Execution blockers that currently prevent the work from moving forward."
        },
        "notes": {
          "type": "array",
