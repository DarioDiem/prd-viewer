{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/prd.schema.strict.v1.2.0.json",
  "title": "PRD Schema (Strict)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "meta",
    "problem",
    "goals",
    "assumptions",
    "personas",
    "requirements",
    "user_stories",
    "constraints",
    "delivery",
    "risks",
    "open_questions",
    "decisions"
  ],
  "properties": {
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "prd_id",
        "title",
        "summary",
        "product_name",
        "document_type",
        "version",
        "status",
        "lifecycle_stage",
        "owners",
        "authors",
        "reviewers",
        "approvers",
        "created_at",
        "updated_at",
        "target_release",
        "stakeholders",
        "source_brief",
        "links"
      ],
      "properties": {
        "prd_id": {
          "type": "string",
          "pattern": "^[0-9a-fA-F-]{36}$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "product_name": {
          "type": "string",
          "minLength": 1
        },
        "document_type": {
          "type": "string",
          "enum": [
            "prd"
          ]
        },
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "status": {
          "type": "string",
          "enum": [
            "draft",
            "in_review",
            "approved",
            "implemented",
            "deprecated"
          ]
        },
        "lifecycle_stage": {
          "type": "string",
          "enum": [
            "discovery",
            "definition",
            "delivery",
            "launch",
            "live"
          ]
        },
        "owners": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "product",
            "engineering",
            "design",
            "business",
            "compliance"
          ],
          "properties": {
            "product": {
              "type": [
                "string",
                "null"
              ]
            },
            "engineering": {
              "type": [
                "string",
                "null"
              ]
            },
            "design": {
              "type": [
                "string",
                "null"
              ]
            },
            "business": {
              "type": [
                "string",
                "null"
              ]
            },
            "compliance": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        },
        "authors": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "reviewers": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "approvers": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        },
        "target_release": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "stakeholders": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/stakeholder"
          }
        },
        "source_brief": {
          "type": [
            "string",
            "null"
          ]
        },
        "links": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/link"
          }
        },
        "schema_contract": {
          "$ref": "#/$defs/schema_contract"
        }
      }
    },
    "problem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "statement",
        "background",
        "opportunity",
        "strategic_fit",
        "affected_users",
        "evidence"
      ],
      "properties": {
        "statement": {
          "type": "string",
          "minLength": 1
        },
        "background": {
          "type": "string",
          "minLength": 1
        },
        "opportunity": {
          "type": "string",
          "minLength": 1
        },
        "strategic_fit": {
          "type": [
            "string",
            "null"
          ]
        },
        "affected_users": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "evidence": {
          "type": "array",
          "minItems": 3,
          "items": {
            "$ref": "#/$defs/evidence"
          }
        }
      }
    },
    "goals": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "business_goals",
        "user_outcomes",
        "success_metrics",
        "guardrail_metrics",
        "non_goals"
      ],
      "properties": {
        "business_goals": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/business_goal"
          }
        },
        "user_outcomes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/user_outcome"
          }
        },
        "success_metrics": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/metric"
          }
        },
        "guardrail_metrics": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/metric"
          }
        },
        "non_goals": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "assumptions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/assumption"
      }
    },
    "personas": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/persona"
      }
    },
    "requirements": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "functional",
        "non_functional"
      ],
      "properties": {
        "functional": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/functional_requirement"
          }
        },
        "non_functional": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_functional_requirement"
          }
        }
      }
    },
    "user_stories": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/user_story"
      }
    },
    "constraints": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "technical",
        "legal_compliance",
        "dependencies"
      ],
      "properties": {
        "technical": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/technical_constraint"
          }
        },
        "legal_compliance": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/legal_compliance"
          }
        },
        "dependencies": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/dependency"
          }
        }
      }
    },
    "delivery": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_launch",
        "milestones",
        "rollout_plan",
        "operational_readiness"
      ],
      "properties": {
        "target_launch": {
          "type": [
            "string",
            "null"
          ],
          "format": "date"
        },
        "milestones": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/milestone"
          }
        },
        "rollout_plan": {
          "$ref": "#/$defs/rollout_plan"
        },
        "operational_readiness": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/readiness_item"
          }
        }
      }
    },
    "project_tracking": {
      "$ref": "#/$defs/project_tracking"
    },
    "risks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/risk"
      }
    },
    "open_questions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/open_question"
      }
    },
    "decisions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/decision"
      }
    },
    "extensions": {
      "$ref": "#/$defs/extensions_container"
    }
  },
  "$defs": {
    "link": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label",
        "url"
      ],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "stakeholder": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "role",
        "team",
        "approval_required"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "type": "string",
          "minLength": 1
        },
        "team": {
          "type": [
            "string",
            "null"
          ]
        },
        "approval_required": {
          "type": "boolean"
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "description",
        "source",
        "confidence",
        "observed_at"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "metric",
            "user_research",
            "competitor",
            "support_ticket",
            "regulatory",
            "internal_data",
            "other"
          ]
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "confidence": {
          "type": "string",
          "enum": [
            "high",
            "medium",
            "low"
          ]
        },
        "observed_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date"
        }
      }
    },
    "business_goal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "statement",
        "rationale",
        "owner",
        "priority"
      ],
      "properties": {
        "statement": {
          "type": "string",
          "minLength": 1
        },
        "rationale": {
          "type": [
            "string",
            "null"
          ]
        },
        "owner": {
          "type": [
            "string",
            "null"
          ]
        },
        "priority": {
          "type": "string",
          "enum": [
            "primary",
            "secondary"
          ]
        }
      }
    },
    "user_outcome": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "actor",
        "desired_outcome",
        "measurement_signal"
      ],
      "properties": {
        "actor": {
          "type": "string",
          "minLength": 1
        },
        "desired_outcome": {
          "type": "string",
          "minLength": 1
        },
        "measurement_signal": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "metric": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "metric",
        "baseline",
        "target",
        "unit",
        "measurement_method",
        "timeframe_days"
      ],
      "properties": {
        "metric": {
          "type": "string",
          "minLength": 1
        },
        "baseline": {
          "type": [
            "string",
            "number",
            "null"
          ]
        },
        "target": {
          "type": [
            "string",
            "number"
          ]
        },
        "unit": {
          "type": "string",
          "minLength": 1
        },
        "measurement_method": {
          "type": "string",
          "minLength": 1
        },
        "timeframe_days": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "assumption": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "assumption_id",
        "statement",
        "category",
        "validation_plan",
        "owner",
        "status"
      ],
      "properties": {
        "assumption_id": {
          "type": "string",
          "pattern": "^A-[0-9]{3}$"
        },
        "statement": {
          "type": "string",
          "minLength": 1
        },
        "category": {
          "type": "string",
          "enum": [
            "user",
            "business",
            "technical",
            "operational",
            "legal",
            "market",
            "data"
          ]
        },
        "validation_plan": {
          "type": [
            "string",
            "null"
          ]
        },
        "owner": {
          "type": [
            "string",
            "null"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "open",
            "validated",
            "invalidated",
            "deferred"
          ]
        }
      }
    },
    "persona": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "persona_id",
        "name",
        "role",
        "goals",
        "needs",
        "pain_points",
        "current_workarounds",
        "frequency_of_use",
        "technical_proficiency",
        "environment"
      ],
      "properties": {
        "persona_id": {
          "type": "string",
          "pattern": "^P-[0-9]{3}$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "type": "string",
          "minLength": 1
        },
        "goals": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "needs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "pain_points": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "current_workarounds": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "frequency_of_use": {
          "type": "string",
          "enum": [
            "daily",
            "weekly",
            "monthly",
            "occasional"
          ]
        },
        "technical_proficiency": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "environment": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "functional_requirement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "req_id",
        "title",
        "description",
        "rationale",
        "priority",
        "persona_ids",
        "dependencies",
        "acceptance_criteria",
        "status",
        "release_phase"
      ],
      "properties": {
        "req_id": {
          "type": "string",
          "pattern": "^FR-[0-9]{3}$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "rationale": {
          "type": [
            "string",
            "null"
          ]
        },
        "priority": {
          "type": "string",
          "enum": [
            "must",
            "should",
            "could",
            "wont"
          ]
        },
        "persona_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^P-[0-9]{3}$"
          }
        },
        "dependencies": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "acceptance_criteria": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "status": {
          "type": "string",
          "enum": [
            "proposed",
            "approved",
            "deferred",
            "removed"
          ]
        },
        "release_phase": {
          "type": "string",
          "enum": [
            "mvp",
            "ga",
            "post_ga",
            "future"
          ]
        }
      }
    },
    "non_functional_requirement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "req_id",
        "category",
        "description",
        "target",
        "priority",
        "acceptance_criteria"
      ],
      "properties": {
        "req_id": {
          "type": "string",
          "pattern": "^NFR-[0-9]{3}$"
        },
        "category": {
          "type": "string",
          "enum": [
            "performance",
            "security",
            "scalability",
            "accessibility",
            "reliability",
            "compliance",
            "usability",
            "observability",
            "privacy"
          ]
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "target": {
          "type": "string",
          "minLength": 1
        },
        "priority": {
          "type": "string",
          "enum": [
            "must",
            "should",
            "could",
            "wont"
          ]
        },
        "acceptance_criteria": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "user_story": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "story_id",
        "epic",
        "persona_id",
        "priority",
        "release_phase",
        "statement",
        "acceptance_criteria",
        "linked_req_ids",
        "story_points",
        "edge_cases"
      ],
      "properties": {
        "story_id": {
          "type": "string",
          "pattern": "^US-[0-9]{3}$"
        },
        "epic": {
          "type": "string",
          "minLength": 1
        },
        "persona_id": {
          "type": "string",
          "pattern": "^P-[0-9]{3}$"
        },
        "priority": {
          "type": "string",
          "enum": [
            "must",
            "should",
            "could"
          ]
        },
        "release_phase": {
          "type": "string",
          "enum": [
            "mvp",
            "ga",
            "post_ga",
            "future"
          ]
        },
        "statement": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "as_a",
            "i_want",
            "so_that"
          ],
          "properties": {
            "as_a": {
              "type": "string",
              "minLength": 1
            },
            "i_want": {
              "type": "string",
              "minLength": 1
            },
            "so_that": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "acceptance_criteria": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/gwt"
          }
        },
        "linked_req_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^(FR|NFR)-[0-9]{3}$"
          }
        },
        "story_points": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "edge_cases": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "gwt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "given",
        "when",
        "then"
      ],
      "properties": {
        "given": {
          "type": "string",
          "minLength": 1
        },
        "when": {
          "type": "string",
          "minLength": 1
        },
        "then": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "technical_constraint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "constraint_id",
        "description",
        "imposed_by",
        "impact"
      ],
      "properties": {
        "constraint_id": {
          "type": "string",
          "pattern": "^TC-[0-9]{3}$"
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "imposed_by": {
          "type": "string",
          "enum": [
            "team",
            "architecture",
            "third_party",
            "platform"
          ]
        },
        "impact": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "legal_compliance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "regulation",
        "requirement",
        "region",
        "owner",
        "evidence_source"
      ],
      "properties": {
        "regulation": {
          "type": "string",
          "minLength": 1
        },
        "requirement": {
          "type": "string",
          "minLength": 1
        },
        "region": {
          "type": "string",
          "minLength": 1
        },
        "owner": {
          "type": [
            "string",
            "null"
          ]
        },
        "evidence_source": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "dependency": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dependency_id",
        "name",
        "description",
        "type",
        "owner",
        "required_by",
        "status"
      ],
      "properties": {
        "dependency_id": {
          "type": "string",
          "pattern": "^D-[0-9]{3}$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": [
            "string",
            "null"
          ]
        },
        "type": {
          "type": "string",
          "enum": [
            "internal",
            "external",
            "third_party",
            "platform"
          ]
        },
        "owner": {
          "type": [
            "string",
            "null"
          ]
        },
        "required_by": {
          "type": [
            "string",
            "null"
          ],
          "format": "date"
        },
        "status": {
          "type": "string",
          "enum": [
            "pending",
            "in_progress",
            "blocked",
            "complete"
          ]
        }
      }
    },
    "milestone": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "date",
        "deliverable",
        "entry_criteria",
