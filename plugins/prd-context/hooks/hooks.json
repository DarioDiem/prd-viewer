{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/hooks/context-reminder.cjs\"",
            "timeout": 5,
            "statusMessage": "Loading PRD context guidance..."
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/hooks/context-reminder.cjs\"",
            "timeout": 5,
            "statusMessage": "Loading PRD context guidance..."
          }
        ]
      }
    ]
  }
}
