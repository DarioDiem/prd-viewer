{
  "name": "prd-viewer",
  "private": true,
  "version": "0.1.0",
  "license": "Apache-2.0",
  "type": "module",
  "description": "Local-first PRD reviewer UI for canonical PRD JSON artifacts.",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json && vite build",
    "check": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "npm run check && npm run test && npm run test:e2e",
    "preview": "vite preview",
    "report:generate": "vite-node scripts/generate-project-status-report.ts"
  },
  "dependencies": {
    "@jsonforms/core": "^3.6.0",
    "@jsonforms/react": "^3.6.0",
    "@jsonforms/vanilla-renderers": "^3.6.0",
    "@xyflow/react": "^12.8.4",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "vanilla-jsoneditor": "^3.8.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.13.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.2",
    "@vitest/coverage-v8": "^3.2.4",
    "jsdom": "^26.1.0",
    "typescript": "^5.8.3",
    "vite": "^7.1.4",
    "vite-node": "^3.2.4",
    "vitest": "^3.2.4"
  }
}
